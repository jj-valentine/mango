<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Intelligence Brief — {{ date }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Non-theme constants */
      --sans:         'DM Sans', system-ui, sans-serif;
      --mono:         'IBM Plex Mono', ui-monospace, monospace;
      --radius:       6px;
      --radius-lg:    10px;

      /* Light theme (default) */
      --bg:           #ffffff;
      --bg-card:      #ffffff;
      --bg-card-alt:  #f6f8fa;
      --bg-hover:     #f3f4f6;
      --border:       #d1d9e0;
      --border-mid:   #b0b8c1;
      --fg:           #1f2328;
      --fg-sub:       #59636e;
      --fg-dim:       #8b949e;
      --fg-ghost:     #b0b8c1;
      --accent:       #3b82f6;
      --accent-dim:   rgba(59,130,246,0.08);
      --accent-glow:  rgba(59,130,246,0.15);
      --lime:         #65a30d;
      --timestamp:    #8250df;
      --timestamp-bg: rgba(130,80,223,0.08);
      --code-fg:      #2563eb;
    }

    [data-theme="dark"] {
      --bg:           #0a0a0a;
      --bg-card:      #111111;
      --bg-card-alt:  #141414;
      --bg-hover:     #181818;
      --border:       rgba(255,255,255,0.07);
      --border-mid:   rgba(255,255,255,0.11);
      --fg:           #f0f0f0;
      --fg-sub:       rgba(255,255,255,0.6);
      --fg-dim:       rgba(255,255,255,0.3);
      --fg-ghost:     rgba(255,255,255,0.12);
      --accent:       #3b82f6;
      --accent-dim:   rgba(59,130,246,0.12);
      --accent-glow:  rgba(59,130,246,0.25);
      --lime:         #84cc16;
      --timestamp:    #bc8cff;
      --timestamp-bg: rgba(188,140,255,0.1);
      --code-fg:      #93c5fd;
    }

    html { background: var(--bg); color: var(--fg); }

    body {
      font-family: var(--sans);
      font-size: 17px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      background: var(--bg);
      min-height: 100vh;
      padding: 48px 16px 80px;
    }

    /* -- Layout --------------------------------------------------------- */
    .page {
      max-width: 880px;
      margin: 0 auto;
    }

    /* -- Theme toggle --------------------------------------------------- */
    .theme-toggle {
      position: fixed;
      top: 20px;
      right: 20px;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--fg-dim);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s, color 0.15s;
      z-index: 100;
    }

    .theme-toggle:hover {
      border-color: var(--border-mid);
      color: var(--fg-sub);
    }

    [data-theme="light"] .icon-sun { display: none; }
    [data-theme="light"] .icon-moon { display: block; }
    [data-theme="dark"] .icon-sun { display: block; }
    [data-theme="dark"] .icon-moon { display: none; }

    /* -- Header --------------------------------------------------------- */
    .header {
      padding-bottom: 40px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 40px;
    }

    .header-eyebrow {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }

    .header-title {
      font-family: var(--sans);
      font-size: clamp(36px, 5.5vw, 50px);
      font-weight: 300;
      letter-spacing: -0.03em;
      color: var(--fg);
      line-height: 1.1;
      margin-bottom: 12px;
    }

    .header-title strong {
      font-weight: 600;
    }

    .header-meta {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg-dim);
      letter-spacing: 0.04em;
    }

    /* -- Section labels ------------------------------------------------- */
    .section-label {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--fg-ghost);
      margin-bottom: 16px;
    }

    /* -- Entity block --------------------------------------------------- */
    .entity-block {
      margin-bottom: 40px;
    }

    .entity-header {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 16px;
    }

    .entity-name {
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--fg);
    }

    .badge {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 2px 7px;
      border-radius: 20px;
      white-space: nowrap;
    }

    .badge-source {
      color: var(--fg-dim);
      background: var(--fg-ghost);
      border: 1px solid var(--border);
    }

    /* -- Video cards ----------------------------------------------------- */
    .video-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 10px;
      transition: border-color 0.15s ease;
    }

    .video-card:hover {
      border-color: var(--border-mid);
    }

    .video-card.is-open {
      border-color: rgba(59,130,246,0.2);
    }

    /* Card trigger row */
    .video-trigger {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 16px 18px;
      cursor: pointer;
      user-select: none;
      -webkit-user-select: none;
    }

    .video-trigger:hover .video-title-text {
      color: var(--fg);
    }

    .video-thumb-wrap {
      flex-shrink: 0;
      width: 120px;
      height: 68px;
      border-radius: 4px;
      overflow: hidden;
      background: var(--bg-card-alt);
      position: relative;
    }

    .video-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .thumb-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--fg-ghost);
      font-size: 22px;
    }

    .video-meta {
      flex: 1;
      min-width: 0;
    }

    .video-title-text {
      font-size: 16px;
      font-weight: 500;
      color: var(--fg-sub);
      line-height: 1.35;
      margin-bottom: 5px;
      transition: color 0.1s ease;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .video-stats {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--fg-ghost);
      letter-spacing: 0.03em;
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
    }

    .stat-dot {
      color: var(--border-mid);
    }

    .pill-tags {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
      margin-top: 6px;
    }

    .pill {
      font-family: var(--mono);
      font-size: 12px;
      padding: 1px 6px;
      border-radius: 3px;
      background: var(--accent-dim);
      color: var(--accent);
      border: 1px solid rgba(59,130,246,0.2);
      letter-spacing: 0.04em;
    }

    .chevron {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--fg-ghost);
      transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1),
                  color 0.15s ease;
    }

    .video-card.is-open .chevron {
      transform: rotate(180deg);
      color: var(--accent);
    }

    /* Expandable body */
    .video-body {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .video-card.is-open .video-body {
      grid-template-rows: 1fr;
    }

    .video-body-inner {
      overflow: hidden;
    }

    .video-body-content {
      padding: 0 18px 20px;
      border-top: 1px solid var(--border);
    }

    /* -- Analysis prose -------------------------------------------------- */
    .analysis {
      font-size: 16px;
      color: var(--fg-sub);
      line-height: 1.75;
      padding-top: 18px;
    }

    .analysis p { margin: 0 0 10px; }
    .analysis p:last-child { margin-bottom: 0; }

    .analysis h1,
    .analysis h2 {
      font-size: 16px;
      font-weight: 600;
      color: var(--fg);
      letter-spacing: -0.01em;
      margin: 20px 0 8px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
    }

    .analysis h1:first-child,
    .analysis h2:first-child { margin-top: 0; }

    .analysis h3 {
      font-size: 14px;
      font-weight: 600;
      color: var(--fg);
      margin: 16px 0 7px;
    }

    .analysis h4 {
      font-size: 14px;
      font-weight: 600;
      color: var(--fg);
      margin: 12px 0 5px;
    }

    .analysis ul, .analysis ol {
      padding-left: 18px;
      margin: 8px 0;
    }

    .analysis li {
      margin-bottom: 5px;
      line-height: 1.6;
    }

    .analysis strong, .analysis b {
      color: var(--fg);
      font-weight: 500;
    }

    .analysis em, .analysis i {
      color: var(--fg-sub);
      font-style: italic;
    }

    .analysis a {
      color: var(--accent);
      text-decoration: none;
    }
    .analysis a:hover { text-decoration: underline; }

    /* Timestamp links (YouTube) — purple pill */
    .analysis a[href*="youtu"],
    .recs-content a[href*="youtu"] {
      color: var(--timestamp);
      font-family: var(--mono);
      font-size: 13px;
      background: var(--timestamp-bg);
      padding: 1px 6px;
      border-radius: 3px;
      text-decoration: none;
    }

    .analysis a[href*="youtu"]:hover,
    .recs-content a[href*="youtu"]:hover {
      text-decoration: underline;
    }

    .analysis code {
      font-family: var(--mono);
      font-size: 13px;
      background: var(--accent-dim);
      border: 1px solid rgba(59,130,246,0.18);
      padding: 1px 5px;
      border-radius: 3px;
      color: var(--code-fg);
    }

    .analysis pre {
      background: var(--bg-card-alt);
      border: 1px solid var(--border);
      padding: 12px 14px;
      border-radius: var(--radius);
      overflow-x: auto;
      margin: 10px 0;
    }

    .analysis pre code {
      background: none;
      border: none;
      padding: 0;
      color: var(--code-fg);
    }

    .analysis blockquote {
      border-left: 2px solid var(--accent);
      margin: 10px 0;
      padding: 6px 14px;
      color: var(--fg-dim);
      background: var(--accent-dim);
      border-radius: 0 3px 3px 0;
    }

    .analysis table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      margin: 10px 0;
    }

    .analysis th {
      text-align: left;
      padding: 6px 10px;
      font-weight: 500;
      color: var(--fg-dim);
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--border-mid);
    }

    .analysis td {
      padding: 7px 10px;
      border-bottom: 1px solid var(--border);
      color: var(--fg-sub);
      vertical-align: top;
    }

    .analysis tr:last-child td { border-bottom: none; }

    /* Frames */
    .frames-section {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
    }

    .frames-label {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--fg-ghost);
      margin-bottom: 10px;
    }

    .frames-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .frame-item { }

    .frame-img {
      width: 100%;
      height: 90px;
      object-fit: cover;
      display: block;
      border-radius: 4px;
      border: 1px solid var(--border);
      background: var(--bg-card-alt);
    }

    .frame-ts {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--timestamp);
      text-decoration: none;
      display: block;
      margin: 4px 0 2px;
      letter-spacing: 0.04em;
    }

    .frame-desc {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--fg-ghost);
      line-height: 1.45;
    }

    /* -- Skipped -------------------------------------------------------- */
    .skipped-notice {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--fg-ghost);
      padding: 8px 18px 14px;
      letter-spacing: 0.03em;
    }

    /* -- Feed analysis -------------------------------------------------- */
    .feed-body {
      padding: 18px;
    }

    /* -- Recommendations ------------------------------------------------ */
    .recs-card {
      background: var(--accent-dim);
      border: 1px solid rgba(59,130,246,0.2);
      border-left: 3px solid var(--accent);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-top: 40px;
    }

    .recs-trigger {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      cursor: pointer;
      user-select: none;
      -webkit-user-select: none;
    }

    .recs-trigger-text { flex: 1; }

    .recs-title {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--fg);
      margin-bottom: 2px;
    }

    .recs-subtitle {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .recs-body {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .recs-card.is-open .recs-body {
      grid-template-rows: 1fr;
    }

    .recs-body-inner {
      overflow: hidden;
    }

    .recs-body-content {
      padding: 0 20px 20px;
      border-top: 1px solid rgba(59,130,246,0.15);
    }

    .recs-card.is-open .chevron {
      transform: rotate(180deg);
      color: var(--accent);
    }

    .recs-content {
      font-size: 16px;
      color: var(--fg-sub);
      line-height: 1.75;
      padding-top: 16px;
    }

    .recs-content p { margin: 0 0 8px; }
    .recs-content p:last-child { margin-bottom: 0; }

    .recs-content h1,
    .recs-content h2,
    .recs-content h3 {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 18px 0 8px;
    }

    .recs-content h1:first-child,
    .recs-content h2:first-child,
    .recs-content h3:first-child { margin-top: 0; }

    .recs-content ul, .recs-content ol { padding-left: 16px; margin: 6px 0; }
    .recs-content li { margin-bottom: 6px; }
    .recs-content strong, .recs-content b { color: var(--fg); font-weight: 500; }
    .recs-content a { color: var(--accent); text-decoration: none; }
    .recs-content code {
      font-family: var(--mono);
      font-size: 13px;
      background: var(--accent-dim);
      border: 1px solid rgba(59,130,246,0.18);
      padding: 1px 5px;
      border-radius: 3px;
      color: var(--code-fg);
    }
    .recs-content hr { border: none; border-top: 1px solid rgba(59,130,246,0.15); margin: 14px 0; }

    /* -- No-new-content ------------------------------------------------- */
    .no-new-section {
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
    }

    .no-new-label {
      font-family: var(--mono);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--fg-ghost);
      margin-bottom: 6px;
    }

    .no-new-items {
      font-family: var(--mono);
      font-size: 14px;
      color: var(--fg-ghost);
    }

    /* -- Footer --------------------------------------------------------- */
    .footer {
      margin-top: 48px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
    }

    .footer-meta {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--fg-ghost);
      letter-spacing: 0.04em;
    }

    /* -- Expand-all control --------------------------------------------- */
    .expand-controls {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      margin-bottom: 12px;
    }

    .expand-btn {
      font-family: var(--mono);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.08em;
      color: var(--fg-dim);
      background: none;
      border: 1px solid var(--border);
      padding: 4px 10px;
      border-radius: 4px;
      cursor: pointer;
      transition: color 0.1s, border-color 0.1s;
    }

    .expand-btn:hover {
      color: var(--fg-sub);
      border-color: var(--border-mid);
    }
  </style>
</head>
<body>

<!-- Theme toggle -->
<button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
  <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<div class="page">

  <!-- Header -->
  <header class="header">
    <p class="header-eyebrow">{{ date }}</p>
    <h1 class="header-title"><strong>Intelligence</strong> Brief</h1>
    <p class="header-meta">
      {{ summaries | length }} source{{ 's' if summaries | length != 1 else '' }}
      &nbsp;&middot;&nbsp;
      {{ summaries | selectattr('has_new_content') | list | length }} with new content
    </p>
  </header>

  <!-- Intelligence section -->
  {% if summaries %}
  <div class="section-label">Intelligence</div>

  {% for summary in summaries %}
  {% if summary.has_new_content %}
  <div class="entity-block">

    <div class="entity-header">
      <span class="entity-name">{{ summary.entity_name }}</span>
      <span class="badge badge-source">
        {%- if summary.source_type == 'youtube' -%}&#9654; youtube
        {%- elif summary.source_type == 'rss' -%}&#9670; rss
        {%- elif summary.source_type == 'api' -%}&#11045; api
        {%- else -%}{{ summary.source_type }}
        {%- endif -%}
      </span>
    </div>

    <!-- YouTube videos -->
    {% if summary.source_type == 'youtube' %}

    {% if summary.video_summaries | length > 1 %}
    <div class="expand-controls">
      <button class="expand-btn" onclick="toggleAll(this)">expand all</button>
    </div>
    {% endif %}

    {% for video in summary.video_summaries %}
    <div class="video-card" id="card-{{ summary.entity_name | replace(' ', '-') }}-{{ loop.index }}">

      <!-- Trigger row -->
      <div class="video-trigger" onclick="toggleCard('card-{{ summary.entity_name | replace(' ', '-') }}-{{ loop.index }}')">
        <div class="video-thumb-wrap">
          {% if video.thumbnail_url %}
          <img class="video-thumb" src="{{ video.thumbnail_url }}" alt="{{ video.title | e }}" loading="lazy">
          {% else %}
          <div class="thumb-placeholder">&#9654;</div>
          {% endif %}
        </div>

        <div class="video-meta">
          <div class="video-title-text">
            <a href="{{ video.url }}" target="_blank" rel="noopener" onclick="event.stopPropagation()" style="color:inherit;text-decoration:none">{{ video.title }}</a>
          </div>
          <div class="video-stats">
            <span>{{ video.duration_str }}</span>
            {% if video.view_count %}
            <span class="stat-dot">&middot;</span>
            <span>{{ "{:,}".format(video.view_count) }} views</span>
            {% endif %}
            {% if video.like_count %}
            <span class="stat-dot">&middot;</span>
            <span>{{ "{:,}".format(video.like_count) }} likes</span>
            {% endif %}
          </div>
          {% if video.tool_mentions %}
          <div class="pill-tags">
            {% for tool in video.tool_mentions[:6] %}
            <span class="pill">{{ tool }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </div>

        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Expandable body -->
      <div class="video-body">
        <div class="video-body-inner">
          <div class="video-body-content">
            {% if video.analysis %}
            <div class="analysis">{{ video.analysis | safe }}</div>
            {% endif %}

            {% if video.frame_descriptions %}
            {% set visible_frames = video.frame_descriptions | selectattr('image_url') | list %}
            {% if visible_frames %}
            <div class="frames-section">
              <div class="frames-label">Key frames</div>
              <div class="frames-grid">
                {% for frame in visible_frames[:5] %}
                <div class="frame-item">
                  <a href="{{ frame.youtube_url }}" target="_blank" rel="noopener">
                    <img class="frame-img" src="{{ frame.image_url }}" alt="Frame at {{ frame.timestamp_sec }}s" loading="lazy">
                  </a>
                  <a href="{{ frame.youtube_url }}" target="_blank" rel="noopener" class="frame-ts">
                    &#8599; {{ frame.timestamp_sec // 60 }}:{{ '%02d' | format(frame.timestamp_sec % 60) }}
                    {%- if frame.chapter_title %} &middot; {{ frame.chapter_title }}{% endif %}
                  </a>
                  {% if frame.description %}
                  <span class="frame-desc">{{ frame.description }}</span>
                  {% endif %}
                </div>
                {% endfor %}
              </div>
            </div>
            {% endif %}
            {% endif %}
          </div>
        </div>
      </div>

      {% if video.error %}
      <div class="skipped-notice">&#9888; {{ video.error }}</div>
      {% endif %}
    </div>
    {% endfor %}

    <!-- Feed / RSS -->
    {% else %}
    <div class="video-card">
      <div class="feed-body">
        {% if summary.feed_summaries and summary.feed_summaries[0].analysis %}
        <div class="analysis">{{ summary.feed_summaries[0].analysis | safe }}</div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% if summary.skipped_count > 0 %}
    <div class="skipped-notice">+ {{ summary.skipped_count }} previously seen item{{ 's' if summary.skipped_count != 1 }} skipped</div>
    {% endif %}

  </div>
  {% endif %}
  {% endfor %}
  {% endif %}

  <!-- Recommendations -->
  {% if recommendations and recommendations.raw_text %}
  <div class="recs-card is-open" id="recs-section">
    <div class="recs-trigger" onclick="toggleRecs()">
      <div class="recs-trigger-text">
        <div class="recs-title">Today's Recommendations</div>
        <div class="recs-subtitle">Synthesized from all sources above</div>
      </div>
      <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="recs-body">
      <div class="recs-body-inner">
        <div class="recs-body-content">
          <div class="recs-content">{{ recommendations.raw_text | safe }}</div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  <!-- No new content -->
  {% if no_new_content %}
  <div class="no-new-section">
    <div class="no-new-label">No new content</div>
    <div class="no-new-items">{{ no_new_content | join(' &middot; ') }}</div>
  </div>
  {% endif %}

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-meta">Generated {{ run_at }} &middot; mango</div>
  </footer>

</div>

<script>
  // Theme toggle with localStorage persistence
  (function() {
    var saved = localStorage.getItem('theme');
    if (saved) document.documentElement.setAttribute('data-theme', saved);
  })();

  function toggleTheme() {
    var html = document.documentElement;
    var next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  }

  function toggleCard(id) {
    var card = document.getElementById(id);
    if (card) card.classList.toggle('is-open');
  }

  function toggleAll(btn) {
    var block = btn.closest('.entity-block');
    var cards = block.querySelectorAll('.video-card');
    var anyOpen = Array.from(cards).some(function(c) { return c.classList.contains('is-open'); });
    cards.forEach(function(c) {
      if (anyOpen) c.classList.remove('is-open');
      else c.classList.add('is-open');
    });
    btn.textContent = anyOpen ? 'expand all' : 'collapse all';
  }

  function toggleRecs() {
    var recs = document.getElementById('recs-section');
    if (recs) recs.classList.toggle('is-open');
  }

  // Open all analysis/recs links in new tabs; auto-open single cards
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.analysis a, .recs-content a').forEach(function(a) {
      a.setAttribute('target', '_blank');
      a.setAttribute('rel', 'noopener');
    });
    var cards = document.querySelectorAll('.video-card');
    if (cards.length === 1) cards[0].classList.add('is-open');
  });
</script>
</body>
</html>
