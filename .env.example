# Required
ANTHROPIC_API_KEY=sk-ant-...

# Required for sending (not needed for --dry-run)
RESEND_API_KEY=re_...

# Optional: needed to read private GitHub repos in the projects section
# In GitHub Actions, GITHUB_TOKEN is auto-provided for public repos
# Add GH_PAT as a secret for private repos
GH_PAT=ghp_...
